import random

target = random.randint(1, 50)

print("Number Guessing Game")

guess = int(input("Enter your guess: "))

while guess != target:
    if guess < target:
        print("Too low!")
    else:
        print("Too high!")

guess = int(input("Try again: "))
print(" Congratulations! You guessed the correct number.")

